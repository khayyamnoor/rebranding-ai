# --- Wadi access ticket (Job 1 / Job 2) ---
# Public key used to VERIFY Wadi tickets (RS256). Safe to expose — it can only
# check tickets, never mint them. Paste the SAME public key Wadi was given.
# Store the PEM on one line with \n between lines.
WADI_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# The Wadi platform's web origin. Only this origin may embed the tool.
WADI_ORIGIN="https://your-wadi-domain.com"

# Ticket scoping — must match what Wadi stamps into tickets for THIS tool.
# Observed from a real Wadi ticket: issuer "wadi", audience = this tool's label.
WADI_TICKET_ISSUER="wadi"
WADI_TICKET_AUDIENCE="diagnostics"

# DEV ONLY — never set in production. Lets scripts/mint-ticket.mjs sign test
# tickets locally (stands in for Wadi). The real private key lives only in Wadi.
WADI_DEV_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Legacy single shared Gemini key — used by the AI routes until BYOK is wired
# (Checkpoint C), after which this is removed.
GEMINI_API_KEY=your_gemini_api_key_here
