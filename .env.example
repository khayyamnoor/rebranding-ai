# --- Wadi integration kit (cross-app standard) ---

# Wadi's PUBLIC ticket key, base64 of the PEM. NOT secret (verify-only).
# Paste the value from the Wadi integration kit (also in Wadi's CLAUDE.md).
NEXT_PUBLIC_WADI_TICKET_PUBLIC_KEY="LS0tLS1CRUdJTiBQVUJMSUMgS0VZ...base64...LS0tLS0K"

# Where Wadi runs — the only origin allowed to embed the tool and send tickets.
# Local handshake test: http://localhost:4000 (the embed harness).
# Production: your real Wadi URL.
NEXT_PUBLIC_WADI_ORIGIN="https://your-wadi-domain.com"

# --- DEV ONLY (never set in production) ---

# Second verify key (base64 PEM), trusted ONLY when NODE_ENV!=production, so a
# locally-minted brandvista ticket works before the Wadi registry can mint one.
NEXT_PUBLIC_WADI_DEV_PUBLIC_KEY="...base64 of dev public key..."

# Lets scripts/mint-ticket.mjs + scripts/embed-serve.mjs sign test tickets
# (stands in for Wadi). The real private key lives only in Wadi.
WADI_DEV_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Legacy single shared Gemini key — used by the AI routes until BYOK is wired
# (Checkpoint C), after which this is removed.
GEMINI_API_KEY=your_gemini_api_key_here
